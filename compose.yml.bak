services:
  db:
    image: postgres:16
    restart: unless-stopped
    environment:
      POSTGRES_DB: mcf
      POSTGRES_USER: mcf
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
    volumes:
      - pgdata:/var/lib/postgresql/data

  bot:
    build: ./bot
    env_file: .env
    depends_on:
      - db
    restart: unless-stopped

volumes:
  pgdata:
